# ─── App ───────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ─── Datastores ────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://trader:trader@localhost:5432/terminal
REDIS_URL=redis://localhost:6379/0

# ─── Market data ───────────────────────────────────────
POLYGON_API_KEY=
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true          # use paper endpoints

# ─── LLM providers ─────────────────────────────────────
# OpenRouter = one OpenAI-compatible endpoint, many models. Swap models
# without code changes by editing LLM_MODEL.
LLM_PROVIDER=openrouter            # openrouter | anthropic | openai | ollama
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=deepseek/deepseek-v4-flash   # verify exact slug on openrouter.ai/models

# Optional fallbacks / alternates
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional LLM tuning
#LLM_MODEL_DEBATE=          # cheaper model for bull/bear debaters (judge keeps LLM_MODEL)
LLM_TIMEOUT_SECONDS=60     # per-call deadline; a hung provider fails the call, not the run
LLM_MAX_RETRIES=1          # SDK retries for transient failures (connect/429/5xx)

# ─── Safety ────────────────────────────────────────────
TRADING_MODE=paper         # paper | live  (live requires explicit human approval)
REQUIRE_HUMAN_APPROVAL=true   # must stay true — startup refuses false
# Kill switch: create this file to halt ALL broker submissions (delete to resume)
KILL_SWITCH_FILE=.private/KILL_SWITCH

# ─── Auth & CORS (set both before any hosted/shared deploy) ─────────────
# Unset API_TOKEN = auth disabled (local dev). Set it and every endpoint
# except /health requires "Authorization: Bearer <token>".
API_TOKEN=
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
PUBLIC_BASE_URL=http://localhost:3000   # link target used in notifications

# ─── Background loops & memory ─────────────────────────
ALERT_AUTO_RESEARCH_PER_HOUR=4   # alert->research cap (rolling hour)
SCAN_AUTO_RESEARCH_PER_HOUR=2    # scan->research cap (audit-counted)
SCAN_AUTO_RESEARCH_ENABLED=false # opt-in scheduled scan loop
REFLECTIONS_LIMIT=5              # past lessons injected per symbol (0 = off)
RUNS_DIR=.private/runs           # backtest run-card artifacts (gitignored)

# ─── Telegram notifications (off unless BOTH set) ──────
# Informational only — approval always happens in the app, never in chat.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
